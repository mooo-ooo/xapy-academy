# Copy this file to .env (gitignored) and fill in actual values.
# Never commit .env. Anyone with access to this server can read these.
#
# Required in EVERY environment: DATABASE_URL, AUTH_SECRET, SITE_URL.
# In production also set AUTH_URL + AUTH_TRUST_HOST. Everything else is optional.

# Database
# MySQL 8. Local Laragon with a root password:
#   mysql://root:YOUR_PASSWORD@localhost:3306/academy_dev
# Create the database first:
#   CREATE DATABASE academy_dev CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# Docker compose (see README): host is the service name `db`:
#   mysql://academy:YOUR_PASSWORD@db:3306/academy
DATABASE_URL="mysql://root:CHANGE_ME@localhost:3306/academy_dev"

# Public site origin (SEO-critical)
# The canonical absolute origin used for sitemap.xml, robots.txt, llms.txt,
# canonical/hreflang links, JSON-LD @ids and OG image URLs. If unset it
# falls back to http://localhost:3000 — so in PRODUCTION this MUST be your
# real https origin or every SEO URL will point at localhost.
#   dev:  http://localhost:3000
#   prod: https://academy.yourdomain.com   (no trailing slash)
SITE_URL="http://localhost:3000"
# Same value, exposed to the browser (used by client components if needed).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth.js v5
# Generate with: openssl rand -base64 32  (or any 32+ byte random string)
AUTH_SECRET="CHANGE_ME_TO_RANDOM_32_BYTES"
# The canonical app URL. Dev: http://localhost:3000. Prod: https://yourdomain.com
AUTH_URL="http://localhost:3000"
# Required when running behind a reverse proxy / in a container (trusts the
# forwarded host headers). Keep "true" for self-hosted prod.
AUTH_TRUST_HOST="true"

# OAuth providers (optional)
# Buttons only render when both ID and SECRET are present, so leaving these
# unset is safe — the site falls back to email/password only.
#
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect URI (dev):  http://localhost:3000/api/auth/callback/google
#   Redirect URI (prod): https://yourdomain.com/api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Site
# Locale guests are forced onto (must be one of the enabled locales, e.g. en, vi).
# Authenticated users override via their preferredLang. Mutable at runtime via
# /admin/settings; this env var is the bootstrap default the proxy/middleware reads.
PUBLIC_LOCALE="en"

# Seeded admin (used once by `pnpm db:seed`)
# Email + name for the first admin account. The password is auto-generated
# and printed to the terminal exactly once on seed — save it.
SEED_ADMIN_EMAIL="admin@academy.local"
SEED_ADMIN_NAME="Site Admin"

# Smoke tests (optional, dev only)
# Used by tools/smoke-*.ts to log in as the seeded admin. Set to the
# password printed by `pnpm db:seed`.
# SMOKE_EMAIL="admin@academy.local"
# SMOKE_PASSWORD=""
