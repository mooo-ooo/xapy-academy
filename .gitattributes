# Shell scripts must stay LF so they execute in Linux containers regardless
# of the contributor's core.autocrlf setting.
*.sh text eol=lf

# Each branch keeps its own .gitignore on merge: main tracks built .next for
# deploy (its .gitignore does NOT list .next), develop ignores .next. The
# "ours" driver makes a merge keep the current branch's .gitignore.
# One-time per clone: git config merge.ours.driver true
.gitignore merge=ours
